# 通义千问 API Key — 阿里云百炼平台: https://bailian.console.aliyun.com
QWEN_API_KEY=sk-...

# 或使用 DashScope 原名
# DASHSCOPE_API_KEY=sk-...

# 模型选择（可选，默认 qwen-plus）
# ANDO_MODEL=qwen-turbo        # 最便宜
# ANDO_MODEL=qwen-plus         # 性价比推荐
# ANDO_MODEL=qwen-max          # 最高质量

# 自定义 API 地址（可选，默认阿里云）
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 服务器（可选）
# ANDO_HOST=127.0.0.1
# ANDO_PORT=8000
